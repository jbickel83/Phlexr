{
  "expo": {
    "name": "CrowdKue",
    "slug": "crowdkue-mobile",
    "scheme": "crowdkue",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#070B14"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#070B14"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
